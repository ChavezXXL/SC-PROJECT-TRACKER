# Cloudflare Pages cache headers
# (Mirrors the old netlify.toml [[headers]] blocks)

# Hashed, fingerprinted assets — cache for 1 year
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker — never cache (needs to update on every deploy)
/sw.js
  Content-Type: application/javascript
  Cache-Control: no-cache

# PWA manifest
/manifest.json
  Content-Type: application/manifest+json
  Cache-Control: no-cache

# Index HTML — short cache so deploys propagate fast
/index.html
  Cache-Control: public, max-age=300

# Brand assets — long cache (rarely change)
/brand/*
  Cache-Control: public, max-age=604800
