rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Sample photos ─────────────────────────────────────────────
    // Public read so any device can display photos without auth.
    // Writes (no Firebase Auth yet) are constrained to small image files so the
    // bucket can't be abused as free hosting for arbitrary/malware content.
    // TODO: require request.auth != null once Firebase Auth is wired up.
    match /sample-photos/{fileName} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // ── Job part photos (moved out of Firestore job docs) ─────────
    match /job-parts/{fileName} {
      allow read:  if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // ── Customer PO photos (uploaded from phone) ──────────────────
    // Full-document photos can be larger; cap at 10MB, images only.
    match /customer-pos/{fileName} {
      allow read:  if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if false;
    }

    // ── Everything else: deny ─────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
